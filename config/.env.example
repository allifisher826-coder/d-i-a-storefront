# Environment Variables Template
# Copy this to .env and fill in your actual values

# STRIPE CONFIGURATION
STRIPE_PUBLIC_KEY=pk_live_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_live_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# PRINTFUL CONFIGURATION
PRINTFUL_API_TOKEN=your_printful_api_token_here

# PRINTIFY CONFIGURATION (Alternative to Printful)
PRINTIFY_API_TOKEN=your_printify_api_token_here
PRINTIFY_SHOP_ID=your_shop_id

# SHOPIFY CONFIGURATION
SHOPIFY_STORE_NAME=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_access_token

# KLAVIYO CONFIGURATION
KLAVIYO_API_KEY=pk_YOUR_KEY
KLAVIYO_PRIVATE_API_KEY=sk_YOUR_KEY

# GENERAL
NODE_ENV=production
SITE_URL=https://d-i-a-systems.com
ADMIN_EMAIL=support@d-i-a.nz
